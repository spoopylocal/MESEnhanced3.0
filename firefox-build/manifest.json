{
  "manifest_version": 3,
  "name": "MES Enhanced 3.0 Public",
  "version": "3.2.0",
  "description": "Firefox build with MES copy enhancements and button color customization.",
  "permissions": [
    "downloads",
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://apirouter.apps.wwt.com/*",
    "https://attachments-api.apps.wwt.com/*",
    "https://mes.apps.wwt.com/*",
    "https://reports.wwt.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://mes.apps.wwt.com/orders/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "mesenhanced3-firefox@wwt.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}
